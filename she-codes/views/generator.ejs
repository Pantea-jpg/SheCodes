<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <link rel="stylesheet" href="./css/reset.css" />
    <link rel="stylesheet" href="./css/general.css" />
    <link rel="stylesheet" href="./css/generator.css" />
    <link rel="stylesheet" href="./css/sidemenu.css" />
    <script type="module" src="./scripts/sidemenu.js"></script>

    <script type="module" src="./scripts/generator.js"></script>

    <title>generator</title>
  </head>

  <body>
    <button class="menu-toggle" id="menuToggle">☰</button>

    <div id="sideMenu" class="side-menu">
      <div class="side-menu-header">
        <div class="brand">🎵 <span>Music Match</span></div>
        <button id="closeMenu" class="close-menu">×</button>
      </div>

      <nav class="side-menu-nav">
        <a class="nav-item active" href="/search">🏠 Home</a>
        <a class="nav-item" href="/generator">🎧 Generator</a>
        <a class="nav-item" href="/collection" id="myCollection"
          >💿 Mijn collectie</a
        >
        <a class="nav-item" href="/login" id="openLogin">🔐 Uitloggen</a>
      </nav>

      <div class="side-menu-user">
        <div class="user-avatar">
          <span id="userInitials">U</span>
        </div>
        <div class="user-info">
          <span class="user-name" id="userName">Username</span>
          <span class="user-role" id="userRole">Rol</span>
        </div>
      </div>

      <div class="side-menu-footer">
        <p>Made with ❤️ for music lovers</p>
      </div>
    </div>

    <div id="overlay" class="overlay"></div>

    <header class="header">
      <!-- injaro dorost kon -->
      <div class="logo">
        <img
          src="https://raw.githubusercontent.com/Pantea-jpg/SheCodes/main/she-codes/public/assets/logo1.png"
          alt="Music Match Logo"
        />
      </div>
      <nav>
        <a id="login" href="/login">Uitloggen</a>
        <a id="learn-more" href="#">Leer meer</a>
      </nav>
    </header>

    <!-- MAIN -->
    <section class="generator-section">
      <main>
        <h1>Afspeellijst Generator</h1>

        <div class="mood-section">
          <h2>Stemming</h2>
          <button>😎 Chill</button>
          <button>🏃 Energiek</button>
          <button>😴 Slaap</button>
          <button>💔 Verdrietig</button>
        </div>

        <div class="genre-section">
          <h2>Genre</h2>
          <button>Hip-Hop</button>
          <button>Pop</button>
          <button>Jazz</button>
        </div>

        <div class="setting-section">
          <div class="setting">
            <label for="duration">Duur</label>
            <select id="duration">
              <option value="15">15 min</option>
              <option value="30">30 min</option>
              <option value="45">45 min</option>
              <option value="60">60 min</option>
            </select>
          </div>

          <div class="setting">
            <label for="tempo">Tempo</label>
            <input type="range" id="tempo" min="0" max="100" />
          </div>

          <div class="setting">
            <label for="popularity">Populariteit</label>
            <select id="popularity">
              <option value="Trending">Trending</option>
              <option value="Nieuw">Nieuw</option>
              <option value="Populair">Populair</option>
            </select>
          </div>
        </div>

        <div class="button-title">
          <button type="button" class="playList-generate">
            Afspeellijst Genereren
          </button>
        </div>

        <section id="playlist"></section>
      </main>

      <!-- <aside class="aside">
        <button id="open-liked">❤️ Mijn afspeellijst</button>
        <a href="/collection" id="myCollection">📚 Mijn collectie</a>
      </aside> -->
    </section>

    <!-- LOGIN MODAL -->
    <div id="loginModal" class="modal">
      <button class="close-1">×</button>
      <div class="modal-content">
        <h2>Inloggen</h2>

        <label>Gebruikersnaam</label>
        <input
          type="text"
          placeholder="bv. gebruiker.123@ap.be"
          id="username"
        />

        <label>Wachtwoord</label>
        <input type="password" placeholder="bv. 123" id="password" />

        <button>Inloggen</button>
      </div>
    </div>

    <div id="infoModal" class="modal">
      <button class="close-3">×</button>
      <div class="modal-content">
        <h2>Music Match</h2>
        <p>
          Music Match is een platform waar je nieuwe muziek kunt ontdekken en
          delen met anderen. Je kunt zoeken naar artiesten, nummers en albums en
          aanbevelingen krijgen op basis van jouw smaak.
        </p>
      </div>
    </div>
  </body>
</html>
