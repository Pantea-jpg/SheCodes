<!DOCTYPE html>
<html lang="fa" dir="ltr">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="stylesheet" href="/css/register.css" />
    <link rel="stylesheet" href="/css/general.css" />
    <script type="module" src="/scripts/register.js"></script>
    <title>Register — MusicApp</title>
  </head>
  <body>
    <header class="header">
      <div class="logo">
        <img
          src="https://raw.githubusercontent.com/Pantea-jpg/SheCodes/main/she-codes/public/assets/logo1.png"
          alt="Music Match Logo"
        />
      </div>
      <nav>
        <a id="login" href="/login">Inloggen</a>
        <a id="learn-more" href="#">Leer meer</a>
      </nav>
    </header>

    <div class="main-content">
      <div class="register-card">
        <h2 class="card-title">Een account aanmaken</h2>
        <p class="card-subtitle">Doe met ons mee</p>

        <form action="/register" method="post">
          <div class="field">
            <label for="fname">Voornaam</label>
            <input type="text" id="fname" placeholder="Pantea" name="fname" />
          </div>
          <div class="field">
            <label for="lname">Achternaam</label>
            <input
              type="text"
              id="lname"
              placeholder="Khodabakhsh"
              name="fname"
            />
          </div>

          <div class="field">
            <label for="username">Gebruikersnaam</label>
            <input
              type="text"
              id="username"
              placeholder="Pantea_78"
              name="username"
            />
          </div>

          <div class="field">
            <label for="email">Email adres</label>
            <input
              type="email"
              id="email"
              placeholder="example@email.com"
              name="email"
            />
          </div>

          <div class="field">
            <label for="password">Wachtwoord</label>
            <input
              type="password"
              id="password"
              placeholder="At least 8 characters"
              name="password"
            />
          </div>

          <div class="field">
            <label for="confirm">Bevestig wachtwoord</label>
            <input
              type="password"
              id="confirm"
              placeholder="Repeat your password"
              name="confirm"
            />
          </div>

          <button class="register-btn" type="submit" onclick="handleRegister()">
            Create Account
          </button>
        </form>

        <div class="divider">
          <hr />
          <span style="color: black">Heb je al een account?</span>
          <hr />
        </div>
        <div class="login-link"><a href="/login">Log hier in</a></div>
      </div>
    </div>
  </body>
</html>
