<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="stylesheet" href="./css/reset.css" />

    <link rel="stylesheet" href="./css/general.css" />
    <link rel="stylesheet" href="./css/search.css" />
    <link rel="stylesheet" href="./css/sidemenu.css" />
    <link rel="stylesheet" href="./css/player.css" />
    <script type="module" src="./scripts/search.js"></script>
    <script type="module" src="./scripts/sidemenu.js"></script>
    <script type="module" src="./scripts/general.js"></script>
    <script type="module" src="./scripts/player.js" defer></script>

    <title>searchPage</title>
  </head>
  <body>
<button class="menu-toggle" id="menuToggle">☰</button>

<div id="sideMenu" class="side-menu">
  <div class="side-menu-header">
    <div class="brand">
      🎵 <span>Music Match</span>
    </div>
    <button id="closeMenu" class="close-menu">×</button>
  </div>

  <nav class="side-menu-nav">
    <a class="nav-item active" href="/search">🏠 Home</a>
    <a class="nav-item" href="/generator">🎧 Generator</a>
    <a class="nav-item" href="/collection" id="myCollection">💿 Mijn collectie</a>
    <a class="nav-item" href="/login" id="openLogin">🔐 Uitloggen</a>
  </nav>


  <div class="side-menu-user">
    <div class="user-avatar">
      <span id="userInitials">U</span>
    </div>
    <div class="user-info">
      <span class="user-name" id="userName">Username</span>
      <span class="user-role" id="userRole">Rol</span>
    </div>
  </div>

  <div class="side-menu-footer">
    <p>Made with ❤️ for music lovers</p>
  </div>
</div>
    
      <header class="header">
        <div class="logo">
          <img src="https://raw.githubusercontent.com/Pantea-jpg/SheCodes/main/she-codes/public/assets/logo1.png" alt="Music Match Logo" />
        </div>
        <nav>
          <a id="login" href="/login">Uitloggen</a>
          <a id="learn-more" href="#">Leer meer</a>
        </nav>
      </header>
      <main>
      <section class="filter-search">
        <div class="search-container">
          <form method="get" action="/search">
            <label for="mySearch"></label>
            <input
              type="text"
              name="q"
              id="mySearch" value="<%= q %>"
              placeholder="Zoek naar artiest of nummer"
            />
            <button class="searchButton" type="submit">Zoeken</button>
          </form>
        </div>
        <div id="filter-container">
         
       
  <button class="tracksbutton active" id="filter-artists">Artiesten</button>
  <button class="artistsbutton" id="filter-tracks">Nummers</button>

        </div>
       
      </section>
      <div id="loginModal" class="modal">
        <button class="close-1">×</button>
        <div class="modal-content">
          <h2 id="login-h2">Inloggen</h2>
          <div id="error-success"></div>
          <div>
            <label for="username">Gebruikersnaam</label>
            <input
              type="text"
              placeholder="bv. gebruiker.123@ap.be"
              id="username"
            />
          </div>
          <div>
            <label for="password">Wachtwoord</label>
            <input type="password" placeholder="bv. 123" id="password" />
          </div>
          <div class="buttons">
            <button class="login-button">Inloggen</button>
            <button class="register-button">Registreren</button>
          </div>
        </div>
      </div>
      <div class="access-denied">
        <button class="close-2">×</button>
        <div class="access-denied-content">
          U hebt geen toegang tot dit project!
        </div>
      </div>
          <a href="/generator" id="create-playlist-btn" class="playlist-btn">
      🎧 Maak jouw afspeellijst
    </a>
    <div id="home-sections">
      <% if (!q) { %>

  <h2 class="section-title">🔥 Trending artiesten</h2>
  <div class="home-row">
  <% artists.forEach(a => { %>
    <div class="home-card">
      <img src="<%= a.image %>" class="home-img round">
      <p><%= a.name %></p>
    </div>
  <% }) %>
</div>

  <h2 class="section-title">🌍 Populaire nummers</h2>
      <div class="home-row">

  <% tracks.forEach(t => { %>
    <div class="home-card">
      <img src="<%= t.image %>" class="home-img round">
      <p><%= t.name %></p>
    </div>
  <% }) %>
      </div>

<% } else { %>
  <section class="search-result">

    <div class="search-result-h2">

 <h2>🔍 Resultaten voor "<%= q %>"</h2>

    </div>

<div id="results">
  
  <% results.forEach(item => { %>

    <div class="result-item" data-type="<%= item.type %>">

      <% if (item.type === "artist") { %>
        <div class="artist-item">
          <img src="<%= item.data.image %>" class="image">
          <div class="artist-name"><p><strong><%= item.data.name %></strong></p></div>
          <a href="/detail/<%= item.data.id %>?q=<%= q %>" class="details-btn">Details</a>
        </div>
      <% } %>

      <% if (item.type === "track") { %>
        <div class="track-item">
          <img src="<%= item.data.image %>" class="image">
          <div class="track-title">
            <p class="track-name"><strong><%= item.data.name %></strong></p>
            <p class="track-artist"><%= item.data.artist %></p>
          </div>

          <div class="btn-play-detail">
            <button 
              class="play-btn tooltip"
              data-url="<%= item.data.previewUrl %>"
              data-tip="Preview beluisteren"
            >
              🎵
            </button>
             <button class="youtube-btn tooltip" data-video="<%= item.data.videoId %>" data-tip="Volledig nummer afspelen" >▶</button>
            <!-- <a href="/detail/<%= item.data.id %>?q=<%= q %>" class="details-btn">Details</a> -->
          </div>
        </div>
      <% } %>

    </div>

  <% }) %>
</div>
</section>
  <% } %>
  <div class="sticky-player">
    <div class="player-inner">
 
      <div class="track-info">
        <div class="cover-art">
          <svg width="22" height="22" viewBox="0 0 24 24" fill="none">
            <circle cx="12" cy="12" r="4" fill="white" opacity="0.9"/>
            <path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm0 14.5c-2.49 0-4.5-2.01-4.5-4.5S9.51 7.5 12 7.5s4.5 2.01 4.5 4.5-2.01 4.5-4.5 4.5z" fill="white" opacity="0.4"/>
          </svg>
        </div>
        <div class="track-meta">
          <p class="track-name" id="track-name">Midnight Echoes</p>
          <p class="artist-name" id="artist-name">Aurora & The Waves</p>
        </div>
        <button class="like-btn" id="like-btn" onclick="toggleLike()">
          <svg id="heart" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/>
          </svg>
        </button>
      </div>
 
      <div class="progress-area">
        <div class="progress-bar" id="progress-bar" onclick="seekBar(event)">
          <div class="progress-fill" id="progress-fill">
            <div class="progress-thumb"></div>
          </div>
        </div>
        <div class="time-row">
          <span class="time-label" id="cur-time">1:24</span>
          <span class="time-label">4:02</span>
        </div>
      </div>
 
      <!-- Controls -->
      <div class="controls">
        <button class="ctrl-btn" id="shuffle-btn" onclick="toggleShuffle()">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <polyline points="16 3 21 3 21 8"/><polyline points="4 20 21 3"/>
            <polyline points="21 16 21 21 16 21"/><line x1="4" y1="4" x2="9" y2="9"/>
          </svg>
        </button>
 
        <button class="skip-btn" onclick="prevTrack()">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor">
            <polygon points="19 20 9 12 19 4 19 20"/>
            <line x1="5" y1="4" x2="5" y2="20" stroke="currentColor" stroke-width="2"/>
          </svg>
        </button>
 
        <button class="play-btn" id="play-btn" onclick="togglePlay()">
          <svg id="play-icon" width="18" height="18" viewBox="0 0 24 24" fill="white">
            <polygon points="5 3 19 12 5 21 5 3"/>
          </svg>
        </button>
 
        <button class="skip-btn" onclick="nextTrack()">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor">
            <polygon points="5 4 15 12 5 20 5 4"/>
            <line x1="19" y1="4" x2="19" y2="20" stroke="currentColor" stroke-width="2"/>
          </svg>
        </button>
 
        <button class="ctrl-btn" id="repeat-btn" onclick="toggleRepeat()">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <polyline points="17 1 21 5 17 9"/>
            <path d="M3 11V9a4 4 0 0 1 4-4h14"/>
            <polyline points="7 23 3 19 7 15"/>
            <path d="M21 13v2a4 4 0 0 1-4 4H3"/>
          </svg>
        </button>
      </div>
    </div>
  </div>

  
  <div class="ad">
    <p>advertisement</p>
  </div>

  
    </main>


    <div id="loginModal" class="modal">
      <button class="close-1">×</button>
      <div class="modal-content">
        <h2 id="login-h2">Inloggen</h2>
        <div>
          <label for="username">Gebruikersnaam</label>
          <input
            type="text"
            placeholder="bv. gebruiker.123@ap.be"
            id="username"
          />
        </div>
        <div>
          <label for="password">Wachtwoord</label>
          <input type="password" placeholder="bv. 123" id="password" />
        </div>
        <button>Inloggen</button>
      </div>
    </div>
    <div id="infoModal" class="modal">
      <button class="close-3">×</button>
      <div class="modal-content" id="info-content">
        <h2>Music Match</h2>
        <p>
          Music Match is een platform waar je nieuwe muziek kunt ontdekken en
          delen met anderen. Je kunt zoeken naar artiesten, nummers en albums en
          aanbevelingen krijgen op basis van jouw smaak. Het doel van Music
          Match is om mensen met dezelfde muzieksmaak met elkaar te verbinden en
          hen te helpen nieuwe favoriete nummers te vinden.
        </p>
      </div>
    </div>
    
  </body>
</html>
