<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="stylesheet" href="./css/reset.css" />
    <link rel="stylesheet" href="./css/general.css" />
    <link rel="stylesheet" href="./css/sidemenu.css" />
    <link rel="stylesheet" href="./css/collection.css" />
    <script src="./scripts/general.js" defer></script>
    <script type="module" src="./scripts/sidemenu.js" defer></script>
    <script src="./scripts/generator.js" defer></script>
    <script type="module" src="./scripts/collection.js" defer></script>
    <title>My collection</title>
  </head>
  <body>
    <button class="menu-toggle" id="menuToggle">☰</button>

    <div id="sideMenu" class="side-menu">
      <div class="side-menu-header">
        <div class="brand">🎵 <span>Music Match</span></div>
        <button id="closeMenu" class="close-menu">×</button>
      </div>

      <nav class="side-menu-nav">
        <a class="nav-item active" href="/search">🏠 Home</a>
        <a class="nav-item" href="/generator">🎧 Generator</a>
        <a class="nav-item" href="/collection" id="myCollection"
          >💿 Mijn collectie</a
        >
        <a class="nav-item" href="/login" id="openLogin">🔐 Uitloggen</a>
      </nav>

      <div class="side-menu-footer">
        <p>Made with ❤️ for music lovers</p>
      </div>
    </div>

    <div id="overlay" class="overlay"></div>
    <header class="header">
      <!-- injaro dorost kon -->
      <div class="logo">
        <img
          src="https://raw.githubusercontent.com/Pantea-jpg/SheCodes/main/she-codes/public/assets/logo1.png"
          alt="Music Match Logo"
        />
      </div>
      <nav>
        <a id="login" href="/login">Uitloggen</a>
        <a id="learn-more" href="#">Leer meer</a>
      </nav>
    </header>
    <main>
      <div class="title">
        <div class="left">
          <h1>My collection</h1>
          <!-- <button class="Mood">Mood</button> -->
        </div>
        <div class="sort">
      <select id="sort" name="sortButton">
  <option value="name">Name</option>
  <option value="artist">Artist</option>
</select>

        </div>

        <form id="searchForm">
          
          <input id="search" name="searchButton" placeholder="Search"/>
          <button type="submit">🔍</button>
        </form>
      </div>
      <section class="Songlist" id="collection-container">
        
      </section>

      <div id="infoModal" class="modal">
        <button class="close-3">×</button>
        <div class="modal-content" id="info-content">
          <h2>Music Match</h2>
          <p>
            Music Match is een platform waar je nieuwe muziek kunt ontdekken en
            delen met anderen. Je kunt zoeken naar artiesten, nummers en albums
            en aanbevelingen krijgen op basis van jouw smaak. Het doel van Music
            Match is om mensen met dezelfde muzieksmaak met elkaar te verbinden
            en hen te helpen nieuwe favoriete nummers te vinden.
          </p>
        </div>
      </div>
    </main>
  </body>
</html>
